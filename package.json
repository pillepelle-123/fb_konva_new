{
  "name": "fb-konva-fullstack",
  "version": "1.0.0",
  "description": "Full-stack React and Node.js application",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\" \"npm run client:pdf-renderer:watch\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "client:pdf-renderer:watch": "cd client && npm run build:pdf-renderer:watch",
    "install-deps": "cd server && npm install && cd ../client && npm install",
    "db:check": "npm --prefix server run db:check",
    "migrate:create": "npm --prefix server run migrate:create --",
    "migrate:up": "npm --prefix server run migrate:up",
    "migrate:down": "npm --prefix server run migrate:down",
    "migrate:status": "npm --prefix server run migrate:status",
    "db:seed": "npm --prefix server run db:seed",
    "db:seed:test": "npm --prefix server run db:seed:test"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}